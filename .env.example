# Supabase public values for the Vite client bundle.
# In Vercel these must be configured with the VITE_ prefix because Vite only
# exposes prefixed variables to browser code at build time.
VITE_SUPABASE_PROJECT_ID="raxpfaawnzhfxxaoqmnw"
VITE_SUPABASE_URL="https://raxpfaawnzhfxxaoqmnw.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_WLFC7hOmjtVz1VcpMmNBTQ_l1Eb1Bje"
# If your hosting already uses Next.js-style names, the app also accepts:
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"

# OAuth providers such as Google/Apple are configured in the Supabase dashboard:
# Authentication > Providers. Add the provider Client ID/Secret there and make
# sure the deployed site URL and redirect URLs include your app origin.

# Server-side runtime values. Only needed if you deploy the server/API routes,
# and never expose the service role key in client-side code.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
LOVABLE_API_KEY="your-lovable-api-key"
LOVABLE_SEND_URL="your-lovable-send-url-if-used"
